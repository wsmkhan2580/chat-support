# Server configuration
PORT=5000
NODE_ENV=development

# MongoDB connection string.
# If left unset or unreachable, the server automatically falls back to an
# in-memory data store so the app remains fully demoable without MongoDB.
MONGODB_URI=mongodb://127.0.0.1:27017/chat_support

# Comma-separated list of allowed CORS origins (the deployed client URL(s))
CLIENT_ORIGIN=http://localhost:5173

# Optional: shared access code staff must enter to open the agent console.
# Change this in production. Never commit real secrets to source control.
AGENT_ACCESS_CODE=repair-shop-staff
